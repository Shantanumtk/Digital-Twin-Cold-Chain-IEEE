# LLM API (KodeKloud OpenAI-compatible proxy)
OPENAI_API_KEY=sk-<API_KEY>
OPENAI_BASE_URL=https://api.ai.kodekloud.com/v1
LLM_MODEL=anthropic/claude-sonnet-4.5

# MongoDB (private IP within VPC)
MONGO_URI=mongodb://<MONGODB_PRIVATE_IP>:27017
MONGO_DB=coldchain

# Redis (EKS NodePort)
REDIS_HOST=<EKS_NODE_IP>
REDIS_PORT=30379

# Kafka (EKS NodePort)
KAFKA_BOOTSTRAP_SERVERS=<EKS_NODE_IP>:30092

# MQTT (localhost on MQTT EC2)
MQTT_BROKER=localhost
MQTT_PORT=1883

# Simulator directory on MQTT EC2
SIMULATOR_DIR=/home/ubuntu/CPSC-597-Digital-Twin-Cold-Chain

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8001