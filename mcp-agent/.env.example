# MCP Agent — Standard OpenAI API
OPENAI_API_KEY=sk-<YOUR_OPENAI_API_KEY>
LLM_MODEL=gpt-4o-mini

# MongoDB (private IP within VPC)
MONGO_URI=mongodb://<MONGODB_PRIVATE_IP>:27017
MONGO_DB=coldchain

# Redis (EKS NodePort)
REDIS_HOST=<EKS_NODE_IP>
REDIS_PORT=30379

# Kafka (EKS NodePort)
KAFKA_BOOTSTRAP_SERVERS=<EKS_NODE_IP>:30092

# MQTT (localhost on MQTT EC2)
MQTT_BROKER=localhost
MQTT_PORT=1883

# Simulator directory on MQTT EC2
SIMULATOR_DIR=/home/ubuntu/Digital-Twin-Cold-Chain-mcp

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8001
